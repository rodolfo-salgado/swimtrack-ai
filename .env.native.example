CUDA_VISIBLE_DEVICES=0

SWIMTRACK_AUTH_TOKEN=replace-with-a-long-random-secret
SWIMTRACK_BACKEND=tensorrt
SWIMTRACK_DEVICE=cuda:0

SWIMTRACK_MODEL_SOURCE_DIR=../swimtrack-poc/artifacts/models
SWIMTRACK_MODEL_CACHE_DIR=./model-cache
SWIMTRACK_ONNX_FILENAME=rtdetrv2_s.onnx
SWIMTRACK_ENGINE_FILENAME=rtdetrv2_s_fp16.engine
SWIMTRACK_BYTETRACK_ROOT=./vendor/ByteTrack

SWIMTRACK_MAX_BATCH_FRAMES=8
SWIMTRACK_MAX_FRAME_BYTES=2000000
SWIMTRACK_MAX_BATCH_BYTES=12000000
SWIMTRACK_MAX_REQUEST_BYTES=16000000
SWIMTRACK_MAX_DECODED_PIXELS=4194304
SWIMTRACK_MAX_METADATA_BYTES=65536
SWIMTRACK_SESSION_TTL_SECONDS=900
SWIMTRACK_TRT_WORKSPACE_GB=4
SWIMTRACK_TRT_FP16=true
