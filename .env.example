SWIMTRACK_AUTH_TOKEN=replace-with-a-long-random-secret
SWIMTRACK_BACKEND=tensorrt
SWIMTRACK_MODEL_SOURCE_DIR=/model-source
SWIMTRACK_MODEL_CACHE_DIR=/model-cache
SWIMTRACK_ONNX_FILENAME=rtdetrv2_s.onnx
SWIMTRACK_ENGINE_FILENAME=rtdetrv2_s_fp16.engine
SWIMTRACK_BYTETRACK_ROOT=/app/vendor/ByteTrack
SWIMTRACK_DEVICE=cuda:0
SWIMTRACK_INPUT_WIDTH=640
SWIMTRACK_INPUT_HEIGHT=640
SWIMTRACK_DIAGNOSTIC_SCORE_FLOOR=0.05
SWIMTRACK_SCORE_THRESHOLD=0.15
SWIMTRACK_PERSON_LABEL=0
SWIMTRACK_MAX_DETECTIONS=20
SWIMTRACK_MIN_BOX_AREA=250
SWIMTRACK_TRACK_THRESHOLD=0.45
SWIMTRACK_TRACK_BUFFER=60
SWIMTRACK_MATCH_THRESHOLD=0.80
SWIMTRACK_MOT20=false
SWIMTRACK_LANE_ROI_ENABLED=true
SWIMTRACK_WEAK_REACTIVATION_ENABLED=true
SWIMTRACK_WEAK_REACTIVATION_SCORE_THRESHOLD=0.10
SWIMTRACK_WEAK_REACTIVATION_MIN_BOX_AREA=64
SWIMTRACK_WEAK_REACTIVATION_MAX_GAP_SECONDS=1.0
SWIMTRACK_WEAK_REACTIVATION_MAX_CENTER_DISTANCE=0.10
SWIMTRACK_FAR_CROP_ENABLED=false
SWIMTRACK_FAR_CROP_LEFT=0.2962962963
SWIMTRACK_FAR_CROP_TOP=0.1111111111
SWIMTRACK_FAR_CROP_RIGHT=0.7037037037
SWIMTRACK_FAR_CROP_BOTTOM=0.5185185185
SWIMTRACK_FAR_CROP_NMS_THRESHOLD=0.50
SWIMTRACK_MAX_BATCH_FRAMES=8
SWIMTRACK_MAX_FRAME_BYTES=2000000
SWIMTRACK_MAX_BATCH_BYTES=12000000
SWIMTRACK_MAX_REQUEST_BYTES=16000000
SWIMTRACK_MAX_DECODED_PIXELS=4194304
SWIMTRACK_MAX_METADATA_BYTES=65536
SWIMTRACK_MAX_VIDEO_BYTES=1073741824
SWIMTRACK_VIDEO_DECODE_BATCH_FRAMES=4
SWIMTRACK_FFMPEG_PATH=ffmpeg
SWIMTRACK_FFPROBE_PATH=ffprobe
SWIMTRACK_VIDEO_PROBE_TIMEOUT_SECONDS=30
SWIMTRACK_SESSION_TTL_SECONDS=900
SWIMTRACK_DECODE_WORKERS=4
SWIMTRACK_PREPROCESS_WORKERS=4
SWIMTRACK_TRT_WORKSPACE_GB=4
SWIMTRACK_TRT_FP16=true
SWIMTRACK_TRT_OPT_BATCH_SIZE=4
SWIMTRACK_TRT_MAX_BATCH_SIZE=8
SWIMTRACK_MODEL_HOST_DIR=./artifacts/models
SWIMTRACK_INPUT_VIDEOS_HOST_DIR=../input_vids
SWIMTRACK_BIND_HOST=127.0.0.1
